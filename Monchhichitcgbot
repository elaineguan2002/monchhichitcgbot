from telegram import Update
from telegram.ext import (
    ApplicationBuilder,
    CommandHandler,
    MessageHandler,
    ContextTypes,
    filters,
)

import os

TOKEN = os.getenv("BOT_TOKEN")

ADMIN_IDS = {
    88738317,  # replace with your Telegram user ID
}

CHANNEL_ID = -1003848901179  # replace with your channel ID

sales = {}
sale_id_counter = 1

# user_id -> {sale_id: paid_qty}
paid_records = {}


def money(cents: int) -> str:
    return f"${cents / 100:.2f}"


def is_admin(user_id: int) -> bool:
    return user_id in ADMIN_IDS


def display_name(user_id=None, username=None, first_name=None) -> str:
    if username:
        return f"@{username}"
    if first_name:
        return first_name
    return str(user_id)


async def notify_admins(context, text):
    for admin_id in ADMIN_IDS:
        try:
            await context.bot.send_message(chat_id=admin_id, text=text)
        except Exception:
            pass


def render_sale_text(sale):
    lines = [
        f"⚡ {sale['name']}",
        f"Price: {money(sale['price'])}",
        f"Remaining: {sale['remaining_qty']}/{sale['total_qty']}",
    ]

    if sale["remaining_qty"] <= 0:
        lines.append("Status: CLAIMED")
    else:
        lines.append("Status: AVAILABLE")

    lines.append("")
    lines.append("💬 Reply to this post with:")
    lines.append("claim")

    return "\n".join(lines)


async def update_sale_post(context, sale_id):
    sale = sales.get(sale_id)
    if not sale:
        return

    text = render_sale_text(sale)

    try:
        if sale.get("is_photo"):
            await context.bot.edit_message_caption(
                chat_id=sale["chat_id"],
                message_id=sale["message_id"],
                caption=text,
            )
        else:
            await context.bot.edit_message_text(
                chat_id=sale["chat_id"],
                message_id=sale["message_id"],
                text=text,
            )
    except Exception:
        pass


def get_claimant(sale, user_id):
    return next((c for c in sale["claimants"] if c["user_id"] == user_id), None)


def allocate_one_unit_to_user(sale, user_id, display):
    existing = get_claimant(sale, user_id)

    if existing:
        existing["qty"] += 1
    else:
        sale["claimants"].append({
            "user_id": user_id,
            "display": display,
            "qty": 1,
        })

    sale["remaining_qty"] -= 1


def get_paid_qty(user_id: int, sale_id: int) -> int:
    return paid_records.get(user_id, {}).get(sale_id, 0)


def set_paid_qty(user_id: int, sale_id: int, qty: int):
    if user_id not in paid_records:
        paid_records[user_id] = {}
    paid_records[user_id][sale_id] = qty


def get_user_claim_lines(user_id: int):
    lines = []

    for sale in sales.values():
        claimant = get_claimant(sale, user_id)
        if claimant:
            subtotal = claimant["qty"] * sale["price"]
            lines.append(f"{sale['name']} x{claimant['qty']} — {money(subtotal)}")

    return lines


def get_user_unpaid_claim_lines_and_total(user_id: int):
    lines = []
    total = 0

    for sale in sales.values():
        claimant = get_claimant(sale, user_id)
        if not claimant:
            continue

        paid_qty = get_paid_qty(user_id, sale["sale_id"])
        unpaid_qty = claimant["qty"] - paid_qty

        if unpaid_qty <= 0:
            continue

        subtotal = unpaid_qty * sale["price"]
        total += subtotal
        lines.append(f"{sale['name']} x{unpaid_qty} — {money(subtotal)}")

    return lines, total


